# Secrets — NEVER commit
.env
.env.local
*.key
*.pem

# macOS
.DS_Store

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/

# SQLite transient sidecar files (WAL/journal/shm) — never integrity-relevant.
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# Per-arm experimental data IS tracked under arms/{arm}/data/ — those records
# are the locked artifact and must be reproducible byte-for-byte. Only the
# obsolete pre-refactor location is ignored.

# Editors
.vscode/
.idea/
*.swp

# Transient judge re-run artifacts (kept locally for diff'ing successive runs;
# never the locked artifact). Prior runs left *.jsonl.bak / *.jsonl.bak2.
*.bak
*.bak[0-9]*

# Runtime logs from harness scripts — useful for live debugging but not part of
# the locked artifact. The graded/cross_judged JSONLs under arms/ are the
# reproducible record; logs are noisy and not deterministic across runs.
harness/logs/
