ANTHROPIC_API_KEY=sk-ant-...
# Optional override for the 1M context beta header if Anthropic changes it:
# ANTHROPIC_1M_CONTEXT_BETA=context-1m-2025-XX-XX

# v2 multi-vendor arms — required when running the corresponding analyst arm.
# v1 (Opus, Sonnet) arms only need ANTHROPIC_API_KEY above; the keys below
# can be omitted if you are not running v2 arms.
OPENAI_API_KEY=sk-proj-...
GEMINI_API_KEY=AI...
DEEPSEEK_API_KEY=sk-...
